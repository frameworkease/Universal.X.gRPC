    "README.md",
    "README.md.meta"
  ],
  "dependencies": {},
  "scripts": {
    "unity-cli:open-project": "npx --yes @rage-against-the-pixel/unity-cli open-project",
    "dotnet:build": "dotnet build",
    "dotnet:restore-force": "rm -rf ~/.nuget/packages && dotnet restore",
    "dotnet:pack": "mkdir -p ./Builds~ && dotnet pack -c Release -o ./Builds~",
    "npm:pack": "mkdir -p ./Builds~ && npm pack --pack-destination ./Builds~",
    "protoc:go_out": "npx --yes protoc --go_out=./Go/internal/Proto --go_opt=paths=import --go-grpc_out=./Go/internal/Proto --go-grpc_opt=paths=import -I ./Proto~ ./Proto~/*.proto"
  }
}
